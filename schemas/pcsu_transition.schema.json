{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Areposytems/governance-constitution/blob/main/schemas/pcsu_transition.schema.json",
  "title": "PCSU State/Schema Transition Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "transition_id",
    "component_id",
    "transition_type",
    "prev_state_hash",
    "next_state_hash",
    "trigger_event_ids",
    "ordering",
    "freshness",
    "reason_code",
    "policy_snapshot_hash",
    "proof_bundle_hash",
    "recorded_at",
    "signatures"
  ],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "transition_id": {
      "type": "string",
      "minLength": 16,
      "maxLength": 256
    },
    "component_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "e.g., SPM-C, AAM, ARGL, CAA, mMRM, or other component instance ID"
    },
    "transition_type": {
      "type": "string",
      "enum": ["STATE", "SCHEMA", "RECONCILIATION_SUBPHASE"]
    },
    "prev_state_hash": {
      "type": "string",
      "minLength": 16,
      "maxLength": 256
    },
    "next_state_hash": {
      "type": "string",
      "minLength": 16,
      "maxLength": 256
    },
    "trigger_event_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": { "type": "string", "minLength": 1, "maxLength": 256 }
    },
    "ordering": {
      "type": "object",
      "additionalProperties": false,
      "required": ["counter", "clock_type"],
      "properties": {
        "clock_type": { "type": "string", "enum": ["MONOTONIC_COUNTER", "LAMPORT", "VECTOR"] },
        "counter": { "type": "integer", "minimum": 0 },
        "vector": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 },
          "description": "Only used when clock_type=VECTOR"
        }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_at", "observed_at", "expiry_at"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "observed_at": { "type": "string", "format": "date-time" },
        "expiry_at": { "type": "string", "format": "date-time", "description": "Time after which this transition must not be applied or relied upon." }
      }
    },
    "reason_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "e.g., STALE_EVENT_REJECTED, CONFLICT_DETECTED, GAP_DETECTED, POLICY_SNAPSHOT_UPDATED, APPROVAL_GRANTED"
    },
    "policy_snapshot_hash": {
      "type": "string",
      "minLength": 16,
      "maxLength": 256
    },
    "lane_schema_hash": {
      "type": "string",
      "minLength": 16,
      "maxLength": 256
    },
    "proof_bundle_hash": {
      "type": "string",
      "minLength": 16,
      "maxLength": 256
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["signer_id", "alg", "sig", "signed_at"],
        "properties": {
          "signer_id": { "type": "string", "minLength": 1, "maxLength": 256 },
          "alg": { "type": "string", "minLength": 1, "maxLength": 64 },
          "sig": { "type": "string", "minLength": 16, "maxLength": 8192 },
          "signed_at": { "type": "string", "format": "date-time" },
          "key_id": { "type": "string", "minLength": 1, "maxLength": 256 }
        }
      }
    }
  }
}
